  "query": "\nSELECT \n  FLOOR(DATEDIFF(CURDATE(), e.seniority_date) / 365.25) AS seniority_years,\n  COUNT(*) AS employee_count\nFROM employees e\nWHERE e.id IN (SELECT DISTINCT employee_id FROM requests)\n  AND e.seniority_date IS NOT NULL\nGROUP BY seniority_years\nORDER BY seniority_years;\n",
